---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Zulu Candids — Memories">
  <header>
    <div class="header-eyebrow">Unfiltered</div>
    <h1>ZULU<br><em>Candids</em></h1>
    <p>Real moments. Real people.</p>
  </header>

  <div class="container">
    <section class="images-section">
      <div class="images-grid">
        {[1, 2, 3, 4, 5, 6].map(i => (
          <div class="image-card"><img loading="lazy" src={`https://picsum.photos/800/600?random=${200 + i}`} alt={`Candid ${i}`} /></div>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
